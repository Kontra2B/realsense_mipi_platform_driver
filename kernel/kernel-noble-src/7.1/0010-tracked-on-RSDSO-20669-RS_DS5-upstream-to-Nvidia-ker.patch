From 0d1cc2b6ae4c91f500304c06f1f6f161fc61e7d9 Mon Sep 17 00:00:00 2001
From: Wojciech Gladysz <kontra.wojciech.gladysz@gmail.com>
Date: Tue, 19 May 2026 11:11:45 +0000
Subject: [PATCH 2/2] tracked on RSDSO-20669: RS_DS5 upstream to Nvidia kernel

---
 drivers/base/core.c                       |  9 +++++++--
 drivers/media/v4l2-core/v4l2-async.c      | 16 +++++++++++-----
 drivers/media/v4l2-core/v4l2-ctrls-core.c |  1 +
 drivers/media/v4l2-core/v4l2-device.c     |  1 +
 drivers/media/v4l2-core/v4l2-fwnode.c     |  2 +-
 drivers/media/v4l2-core/v4l2-subdev.c     |  2 +-
 drivers/of/property.c                     |  1 +
 7 files changed, 23 insertions(+), 9 deletions(-)

diff --git a/drivers/base/core.c b/drivers/base/core.c
index 0083bc089f3a..157d961679c1 100644
--- a/drivers/base/core.c
+++ b/drivers/base/core.c
@@ -766,6 +766,7 @@ struct device_link *device_link_add(struct device *consumer,
 	if (!device_pm_initialized(supplier)
 	    || (!(flags & DL_FLAG_SYNC_STATE_ONLY) &&
 		  device_is_dependent(consumer, supplier))) {
+		// pr_info("[WOJTEK] %s/1: %x\n", __func__, flags);
 		link = NULL;
 		goto out;
 	}
@@ -777,6 +778,7 @@ struct device_link *device_link_add(struct device *consumer,
 	if (flags & DL_FLAG_SYNC_STATE_ONLY &&
 	    consumer->links.status != DL_DEV_NO_DRIVER &&
 	    consumer->links.status != DL_DEV_PROBING) {
+		// pr_info("[WOJTEK] %s/2: %pOF/%x/%x\n", __func__, consumer->of_node, flags, consumer->links.status);
 		link = NULL;
 		goto out;
 	}
@@ -789,7 +791,9 @@ struct device_link *device_link_add(struct device *consumer,
 	if (flags & DL_FLAG_AUTOREMOVE_SUPPLIER)
 		flags &= ~DL_FLAG_AUTOREMOVE_CONSUMER;
 
+	// pr_info("[WOJTEK] %s/3: %pOF\n", __func__, consumer->of_node);
 	list_for_each_entry(link, &supplier->links.consumers, s_node) {
+		// pr_info("[WOJTEK] %s/4: %pOF\n", __func__, link->consumer->of_node);
 		if (link->consumer != consumer)
 			continue;
 
@@ -922,6 +926,7 @@ struct device_link *device_link_add(struct device *consumer,
 	if ((flags & DL_FLAG_PM_RUNTIME && flags & DL_FLAG_RPM_ACTIVE) && !link)
 		pm_runtime_put(supplier);
 
+	// pr_info("[WOJTEK] %s/5: %p\n", __func__, link);
 	return link;
 }
 EXPORT_SYMBOL_GPL(device_link_add);
@@ -2115,14 +2120,14 @@ static int fw_devlink_create_devlink(struct device *con,
 		if (sup_dev->links.status == DL_DEV_NO_DRIVER &&
 		    sup_handle->flags & FWNODE_FLAG_INITIALIZED) {
 			dev_dbg(con,
-				"Not linking %pfwf - dev might never probe\n",
+				"not linking %pfwf - dev might never probe\n",
 				sup_handle);
 			ret = -EINVAL;
 			goto out;
 		}
 
 		if (con != sup_dev && !device_link_add(con, sup_dev, flags)) {
-			dev_err(con, "Failed to create device link (0x%x) with %s\n",
+			dev_err(con, "failed to create device link (0x%x) with %s\n",
 				flags, dev_name(sup_dev));
 			ret = -EINVAL;
 		}
diff --git a/drivers/media/v4l2-core/v4l2-async.c b/drivers/media/v4l2-core/v4l2-async.c
index 9635bf57c51e..ab92f79da113 100644
--- a/drivers/media/v4l2-core/v4l2-async.c
+++ b/drivers/media/v4l2-core/v4l2-async.c
@@ -553,8 +553,9 @@ static int v4l2_async_nf_match_valid(struct v4l2_async_notifier *notifier,
 		}
 		break;
 	default:
-		dev_err(dev, "v4l2-async: Invalid match type %u on %p\n",
-			match->type, match);
+		if (match)
+			dev_err(dev, "v4l2-async: Invalid match type %u on %p\n",
+					match->type, match);
 		return -EINVAL;
 	}
 
@@ -708,6 +709,8 @@ __v4l2_async_nf_add_fwnode(struct v4l2_async_notifier *notifier,
 	asc->notifier = notifier;
 	asc->match.type = V4L2_ASYNC_MATCH_TYPE_FWNODE;
 	asc->match.fwnode = fwnode_handle_get(fwnode);
+	INIT_LIST_HEAD(&asc->asc_entry);
+	INIT_LIST_HEAD(&asc->asc_subdev_entry);
 
 	__v4l2_async_nf_add_connection(notifier, asc);
 
@@ -751,6 +754,8 @@ __v4l2_async_nf_add_i2c(struct v4l2_async_notifier *notifier, int adapter_id,
 	asc->match.type = V4L2_ASYNC_MATCH_TYPE_I2C;
 	asc->match.i2c.adapter_id = adapter_id;
 	asc->match.i2c.address = address;
+	INIT_LIST_HEAD(&asc->asc_entry);
+	INIT_LIST_HEAD(&asc->asc_subdev_entry);
 
 	__v4l2_async_nf_add_connection(notifier, asc);
 
@@ -790,7 +795,7 @@ int v4l2_async_register_subdev(struct v4l2_subdev *sd)
 {
 	struct v4l2_async_notifier *subdev_notifier;
 	struct v4l2_async_notifier *notifier;
-	struct v4l2_async_connection *asc;
+	struct v4l2_async_connection *asc = NULL;
 	int ret;
 
 	INIT_LIST_HEAD(&sd->asc_list);
@@ -820,12 +825,13 @@ int v4l2_async_register_subdev(struct v4l2_subdev *sd)
 			continue;
 
 		while ((asc = v4l2_async_find_match(notifier, sd))) {
-			ret = v4l2_async_match_notify(notifier, v4l2_dev, sd,
-						      asc);
+			ret = v4l2_async_match_notify(notifier, v4l2_dev, sd, asc);
+			dev_dbg(v4l2_dev->dev, "async match notify\n");
 			if (ret)
 				goto err_unbind;
 
 			ret = v4l2_async_nf_try_complete(notifier);
+			dev_dbg(v4l2_dev->dev, "async nf try complete\n");
 			if (ret)
 				goto err_unbind;
 		}
diff --git a/drivers/media/v4l2-core/v4l2-ctrls-core.c b/drivers/media/v4l2-core/v4l2-ctrls-core.c
index a662fb60f73f..57e033a146a3 100644
--- a/drivers/media/v4l2-core/v4l2-ctrls-core.c
+++ b/drivers/media/v4l2-core/v4l2-ctrls-core.c
@@ -2479,6 +2479,7 @@ int __v4l2_ctrl_handler_setup(struct v4l2_ctrl_handler *hdl)
 			}
 		}
 		ret = call_op(master, s_ctrl);
+		// pr_info("[WOJTEK] %s/%d: %s\n", __func__, ret, master->name);
 		if (ret)
 			break;
 	}
diff --git a/drivers/media/v4l2-core/v4l2-device.c b/drivers/media/v4l2-core/v4l2-device.c
index d2e58ae91f9b..853e7679b043 100644
--- a/drivers/media/v4l2-core/v4l2-device.c
+++ b/drivers/media/v4l2-core/v4l2-device.c
@@ -114,6 +114,7 @@ int v4l2_device_register_subdev(struct v4l2_device *v4l2_dev,
 	int err;
 
 	/* Check for valid input */
+
 	if (!v4l2_dev || !sd || sd->v4l2_dev || !sd->name[0])
 		return -EINVAL;
 
diff --git a/drivers/media/v4l2-core/v4l2-fwnode.c b/drivers/media/v4l2-core/v4l2-fwnode.c
index 89c7192148df..f22ca76a0d1a 100644
--- a/drivers/media/v4l2-core/v4l2-fwnode.c
+++ b/drivers/media/v4l2-core/v4l2-fwnode.c
@@ -567,7 +567,7 @@ int v4l2_fwnode_parse_link(struct fwnode_handle *fwnode,
 	fwnode_graph_parse_endpoint(fwnode, &fwep);
 	link->local_id = fwep.id;
 	link->local_port = fwep.port;
-	link->local_node = fwnode_graph_get_port_parent(fwnode);
+	link->local_node = fwnode;
 	if (!link->local_node)
 		return -ENOLINK;
 
diff --git a/drivers/media/v4l2-core/v4l2-subdev.c b/drivers/media/v4l2-core/v4l2-subdev.c
index 8d748404976b..25bc8bcaf174 100644
--- a/drivers/media/v4l2-core/v4l2-subdev.c
+++ b/drivers/media/v4l2-core/v4l2-subdev.c
@@ -1568,7 +1568,7 @@ __v4l2_subdev_state_get_format(struct v4l2_subdev_state *state,
 		if (stream)
 			return NULL;
 
-		if (state->sd && pad >= state->sd->entity.num_pads)
+		if (!state->sd || pad >= state->sd->entity.num_pads)
 			return NULL;
 
 		return &state->pads[pad].format;
diff --git a/drivers/of/property.c b/drivers/of/property.c
index b81168d99033..14e10206c1fa 100644
--- a/drivers/of/property.c
+++ b/drivers/of/property.c
@@ -666,6 +666,7 @@ struct device_node *of_graph_get_next_endpoint(const struct device_node *parent,
 
 		if (!port) {
 			pr_err("graph: no port node found in %pOF\n", parent);
+			WARN_ON(true);
 			return NULL;
 		}
 	} else {
-- 
