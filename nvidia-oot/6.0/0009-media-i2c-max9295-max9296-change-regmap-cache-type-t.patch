From 7771a65032cb5042fe1717f002f14b9705bb1dc2 Mon Sep 17 00:00:00 2001
From: Nikolai-L <nlyskov@realsenseai.com>
Date: Tue, 31 Mar 2026 11:47:17 +0300
Subject: [PATCH] media: i2c: max9295/max9296: change regmap cache type to
 REGCACHE_NONE

---
 drivers/media/i2c/max9295.c | 2 +-
 drivers/media/i2c/max9296.c | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/drivers/media/i2c/max9295.c b/drivers/media/i2c/max9295.c
index 12b5db00..2149b1a8 100644
--- a/drivers/media/i2c/max9295.c
+++ b/drivers/media/i2c/max9295.c
@@ -498,7 +498,7 @@ EXPORT_SYMBOL(max9295_sdev_unpair);
 static  struct regmap_config max9295_regmap_config = {
 	.reg_bits = 16,
 	.val_bits = 8,
-	.cache_type = REGCACHE_RBTREE,
+	.cache_type = REGCACHE_NONE,
 };
 
 struct reg_pair {
diff --git a/drivers/media/i2c/max9296.c b/drivers/media/i2c/max9296.c
index 92b483b6..d6f9f30c 100644
--- a/drivers/media/i2c/max9296.c
+++ b/drivers/media/i2c/max9296.c
@@ -1060,7 +1060,7 @@ static int max9296_parse_dt(struct max9296 *priv,
 static struct regmap_config max9296_regmap_config = {
 	.reg_bits = 16,
 	.val_bits = 8,
-	.cache_type = REGCACHE_RBTREE,
+	.cache_type = REGCACHE_NONE,
 };
 
 #if defined(NV_I2C_DRIVER_STRUCT_PROBE_WITHOUT_I2C_DEVICE_ID_ARG) /* Linux 6.3 */
-- 
2.43.0

