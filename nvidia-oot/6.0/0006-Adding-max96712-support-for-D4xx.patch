+static int max96712_set_registers(struct max96712 *priv, struct reg_pair *map, u32 count)
+{
+	int err = 0;
+	u32 j = 0;
+
+	for (j = 0; j < count; j++) {
+		err = max96712_write_reg(priv, map[j].addr, map[j].val);
+		if (err != 0)
+			break;
+	}
+
+	return err;
+}
