+void max96712_reset_oneshot(struct device *dev)
+{
+	struct max96712 *priv = dev_get_drvdata(dev);
+	max96712_write_reg(priv, MAX96712_CTRL1_ADDR, 0x0F);
+	msleep(100);
+}
