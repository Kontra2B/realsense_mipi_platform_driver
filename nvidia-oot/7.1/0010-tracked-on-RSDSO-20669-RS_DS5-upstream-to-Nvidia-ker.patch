-int max9295_setup_control(struct device *dev)
-{
-	struct max9295 *priv = dev_get_drvdata(dev);
-	int err = 0;
-	struct gmsl_link_ctx *g_ctx;
-	u32 offset1 = 0;
-	u32 offset2 = 0;
-	u32 i;
-
-	u8 i2c_ovrd[] = {
-		0x6B, 0x10,
-		0x73, 0x11,
-		0x7B, 0x30,
-		0x83, 0x30,
-		0x93, 0x30,
-		0x9B, 0x30,
-		0xA3, 0x30,
-		0xAB, 0x30,
-		0x8B, 0x30,
-	};
-
-	u8 addr_offset[] = {
-		0x80, 0x00, 0x00,
-		0x84, 0x00, 0x01,
-		0xC0, 0x02, 0x02,
-		0xC4, 0x02, 0x03,
-	};
-
-	mutex_lock(&priv->lock);
-
-	if (!priv->g_client.g_ctx) {
-		dev_err(dev, "%s: no sensor dev client found\n", __func__);
-		err = -EINVAL;
-		goto error;
-	}
-
-	g_ctx = priv->g_client.g_ctx;
-
-	if (!priv->external_addr_reassign) {
-		if (prim_priv__) {
-			/* update address reassingment */
-			max_write_reg(&prim_priv__->i2c_client->dev,
-					MAX9295_DEV_ADDR, (g_ctx->ser_reg << 1));
-		}
-
-		if (g_ctx->serdes_csi_link == GMSL_SERDES_CSI_LINK_A)
-			err = max_write_reg(dev, MAX9295_CTRL0_ADDR, 0x21);
-		else
-			err = max_write_reg(dev, MAX9295_CTRL0_ADDR, 0x22);
-
-		/* check if serializer device exists */
-		if (err) {
-			dev_err(dev, "%s: ERROR: ser device not found\n", __func__);
-			goto error;
-		}
-
-		/* delay to settle link */
-		msleep(100);
-
-		for (i = 0; i < ARRAY_SIZE(addr_offset); i += 3) {
-			if ((g_ctx->ser_reg << 1) == addr_offset[i]) {
-				offset1 = addr_offset[i+1];
-				offset2 = addr_offset[i+2];
-				break;
-			}
-		}
-
-		if (i == ARRAY_SIZE(addr_offset)) {
-			dev_err(dev, "%s: invalid ser slave address\n", __func__);
-			err = -EINVAL;
-			goto error;
-		}
-
-		for (i = 0; i < ARRAY_SIZE(i2c_ovrd); i += 2) {
-			/* update address overrides */
-			i2c_ovrd[i+1] += (i < 4) ? offset1 : offset2;
-
-			/* i2c passthrough2 must be configured once for all devices */
-			if ((i2c_ovrd[i] == 0x8B) && prim_priv__ &&
-					prim_priv__->pst2_ref)
-				continue;
-
-			max_write_reg(dev, i2c_ovrd[i], i2c_ovrd[i+1]);
-		}
-	}
-
-	/* dev addr pass-through2 ref */
-	if (prim_priv__)
-		prim_priv__->pst2_ref++;
-
-	max_write_reg(dev, MAX9295_I2C4_ADDR, (g_ctx->sdev_reg << 1));
-	max_write_reg(dev, MAX9295_I2C5_ADDR, (g_ctx->sdev_def << 1));
-
-	max_write_reg(dev, MAX9295_SRC_PWDN_ADDR, MAX9295_PWDN_GPIO);
-	max_write_reg(dev, MAX9295_SRC_CTRL_ADDR, MAX9295_RESET_SRC);
-	max_write_reg(dev, MAX9295_SRC_OUT_RCLK_ADDR, MAX9295_SRC_RCLK);
-
-	g_ctx->serdev_found = true;
-
-error:
-	mutex_unlock(&priv->lock);
-	return err;
-}
