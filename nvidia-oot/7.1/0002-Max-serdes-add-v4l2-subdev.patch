+	priv->sd.flags |= V4L2_SUBDEV_FL_HAS_DEVNODE;
+	for (int i = 1; i < MAX96712_MAX_LINKS + 1; i++)
+		pad[i].index = MEDIA_PAD_FL_SOURCE;
+	pad->flags = MEDIA_PAD_FL_SINK;
+	media_entity_pads_init(entity, MAX96712_MAX_LINKS + 1, pad);
