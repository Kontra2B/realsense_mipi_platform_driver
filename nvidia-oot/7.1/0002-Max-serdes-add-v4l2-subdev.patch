+static int max_bind_ser_to_dser_pipe(struct device *, int, int, u32) __attribute__((unused));
+static int max_bind_ser_to_dser_pipe(struct device *dev, int dser_pipe_id, int ser_pipe_id, u32 vc_id)
+{
